    "_rev": "jR36JPyYnZ2kFBEbLOg1jw",
    "_type": "boat",
    "_updatedAt": "2026-07-16T22:22:21Z",
    "cabinsHeading": "Cabins",
    "cabinsIntro": [
      {
        "_key": "k7",
        "_type": "block",
        "children": [
          {
            "_key": "k8",
            "_type": "span",
            "marks": [],
            "text": "Step straight from the ocean to sea views and easy access to the rest of the boat — all from the comfort of your cabin. All three Deluxe and four Superior cabins come with private air conditioning and an ensuite bathroom with hot water, ready whenever you need to recharge between dives."
          }
        ],
        "markDefs": [],
        "style": "normal"
      }
    ],
    "coverImage": {
      "_type": "imageWithAlt",
      "alt": "Mari Liveaboard underway at sea",
      "asset": {
        "_ref": "image-ba83f0718d0a8ccc6e490c680ffe569e309829f6-1448x1086-jpg",
        "_type": "reference"
      }
    },
    "faqSections": [
      {
        "_key": "f56",
        "_type": "faqSection",
        "questions": [
          {
            "_key": "f57",
            "_type": "faqItem",
            "answer": [
              {
                "_key": "f58",
                "_type": "block",
                "children": [
                  {
                    "_key": "f59",
                    "_type": "span",
                    "text": "Mari is built for serious divers who want a premium liveaboard at exceptional value. It carries a maximum of 14 guests, so the boat stays uncrowded and the diving stays the focus."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              },
              {
                "_key": "f60",
                "_type": "block",
                "children": [
                  {
                    "_key": "f61",
                    "_type": "span",
                    "text": "It suits certified divers who would rather spend their time in the water than on a large, busy vessel. Non-diving partners are welcome, though the program is built around the dive schedule."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              }
            ],
            "isFeatured": true,
            "question": "Who is Mari suitable for?"
          },
          {
            "_key": "f62",
            "_type": "faqItem",
            "answer": [
              {
                "_key": "f63",
                "_type": "block",
                "children": [
                  {
                    "_key": "f64",
                    "_type": "span",
                    "text": "Yes. Nitrox is produced on board with an NRC membrane system and is available to certified Nitrox divers at additional cost."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              },
              {
                "_key": "f65",
                "_type": "block",
                "children": [
                  {
                    "_key": "f66",
                    "_type": "span",
                    "text": "Bring your Nitrox certification card. Fills are charged per day and can be paid in cash on board."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              }
            ],
            "isFeatured": true,
            "question": "Is Nitrox available on board?"
          },
          {
            "_key": "f67",
            "_type": "faqItem",
            "answer": [
              {
                "_key": "f68",
                "_type": "block",
                "children": [
                  {
                    "_key": "f69",
                    "_type": "span",
                    "text": "Open Water certification with at least 30 logged dives is required on every Mari cruise."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              },
              {
                "_key": "f70",
                "_type": "block",
                "children": [
                  {
                    "_key": "f71",
                    "_type": "span",
                    "text": "Many of the sites we visit carry real current, so this baseline applies regardless of destination. Proof of certification is checked before your first dive."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              }
            ],
            "isFeatured": true,
            "question": "What is the minimum diving experience required?"
          },
          {
            "_key": "f72",
            "_type": "faqItem",
            "answer": [
              {
                "_key": "f73",
                "_type": "block",
                "children": [
                  {
                    "_key": "f74",
                    "_type": "span",
                    "text": "Mari carries 14 crew for a maximum of 14 guests, a ratio of 1:1."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              },
              {
                "_key": "f75",
                "_type": "block",
                "children": [
                  {
                    "_key": "f76",
                    "_type": "span",
                    "text": "Four of them are dive staff: a cruise director and three dive guides. That works out to up to four divers per guide in the water."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              }
            ],
            "isFeatured": true,
            "question": "What is the crew-to-guest ratio?"
          },
          {
            "_key": "f77",
            "_type": "faqItem",
            "answer": [
              {
                "_key": "f78",
                "_type": "block",
                "children": [
                  {
                    "_key": "f79",
                    "_type": "span",
                    "text": "Yes. Regulators, BCDs, wetsuits, fins, boots, computers, torches and reef hooks are all available to rent on board, charged per day."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              },
              {
                "_key": "f80",
                "_type": "block",
                "children": [
                  {
                    "_key": "f81",
                    "_type": "span",
                    "text": "Rental gear must be requested in advance so we can confirm sizes and availability before you travel."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              }
            ],
            "question": "Is dive equipment available to rent?"
          },
          {
            "_key": "f82",
            "_type": "faqItem",
            "answer": [
              {
                "_key": "f83",
                "_type": "block",
                "children": [
                  {
                    "_key": "f84",
                    "_type": "span",
                    "text": "Wi-Fi is free on board and works whenever the boat is within range of a mobile network."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              },
              {
                "_key": "f85",
                "_type": "block",
                "children": [
                  {
                    "_key": "f86",
                    "_type": "span",
                    "text": "Many of the best dive sites are remote, so expect stretches of the cruise with no signal at all."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              }
            ],
            "question": "Is there Wi-Fi on board?"
          },
          {
            "_key": "f87",
            "_type": "faqItem",
            "answer": [
              {
                "_key": "f88",
                "_type": "block",
                "children": [
                  {
                    "_key": "f89",
                    "_type": "span",
                    "text": "Up to four dives a day: typically at 7:00am, 10:00am and 2:00pm, plus a night dive at 6:30pm when one is scheduled."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              },
              {
                "_key": "f90",
                "_type": "block",
                "children": [
                  {
                    "_key": "f91",
                    "_type": "span",
                    "text": "An 11-night cruise runs up to 33 dives in total. Maximum dive time is 70 minutes and maximum depth is 40m (131ft)."
                  }
                ],
                "markDefs": [],
                "style": "normal"
              }
            ],
            "question": "How many dives are there per day?"
          }
        ],
        "title": "General Information"
      }
    ],
    "galleryDescription": [
      {
        "_key": "k9",
        "_type": "block",
        "children": [
          {
            "_key": "k10",
            "_type": "span",
            "marks": [],
            "text": "A closer look at life aboard Mari — the boat itself, the food, and the spaces built for unwinding between dives."
          }
        ],
        "markDefs": [],
        "style": "normal"
      }
    ],
    "galleryTitle": "Gallery",
    "keyFeatures": [
      "Max. 14 guests for a relaxed, uncrowded atmosphere",
      "7 ensuite, air-conditioned sea-view cabins, all on the main deck",
      "14 experienced crew members, including 3 dive guides and a dedicated cruise director",
      "Spacious outdoor dining, lounge, and sun decks",
      "Large dive deck, nitrox, and quality rental equipment",
      "3 tenders, including one dedicated to snorkelers and excursions"
    ],
    "keyFeaturesHeading": "Key features",
