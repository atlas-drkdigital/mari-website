# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local-only / internal, never committed — standard convention: prefix with "_" at repo ROOT
# (handoff docs, skill packaging, scratch/test output, etc.). Root-anchored only (no /**/_*) — Next.js
# App Router uses "_"-prefixed folders inside src/app/ as a real, committed routing convention
# (e.g. _components/, _lib/), and this must never touch those.
/_*

# EXCEPTIONS (Adinda, 2026-07-23): the load-bearing working docs ARE committed — git+GitHub is the
# project's real backup (repo is private, DRK-internal; none of this is served by the deployed site).
# Still ignored on purpose: _backup/ (stale file copies), _image-test/ + _content/ images (masters
# live in Google Drive + Sanity), logs, zips, and any future _* scratch.
!/_*.md
!/_handoff/
!/_scripts/
